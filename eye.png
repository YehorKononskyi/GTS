/* GTS INTERNATIONAL — Typography
   Two families: Gilroy (headings/display, self-hosted), Verdana (body/system). */

:root {
  /* Family stacks — Gilroy self-hosted; Montserrat kept as a deep fallback. */
  --font-display: var(--secondary-font, "Gilroy"), "Montserrat", system-ui, sans-serif;
  --font-body: var(--main-font, "Verdana"), Verdana, Geneva, system-ui, sans-serif;

  /* Weights */
  --fw-regular: 400; /* @kind font */
  --fw-medium: 500; /* @kind font */
  --fw-semibold: 600; /* @kind font */
  --fw-bold: 700; /* @kind font */
  --fw-extrabold: 800; /* @kind font */

  /* Type scale */
  --fs-display: 64px;
  --fs-h1: 48px;
  --fs-h2: 36px;
  --fs-h3: 24px;
  --fs-body-lg: 18px;
  --fs-body: 16px;
  --fs-caption: 13px;

  /* Line heights */
  --lh-tight: 1.05; /* @kind font */
  --lh-heading: 1.15; /* @kind font */
  --lh-body: 1.5; /* @kind font */

  /* Tracking */
  --ls-tight: -0.02em; /* @kind font */
  --ls-normal: 0; /* @kind font */
  --ls-wide: 0.08em; /* @kind font */
}
